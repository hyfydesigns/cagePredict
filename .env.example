# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# UFC data API — set APISPORTS_KEY (preferred) OR RAPIDAPI_KEY (legacy fallback)
# api-sports.io MMA API: https://api-sports.io/sports/mma  (100 req/day free)
# APISPORTS_KEY=your-api-sports-key-here
# APISPORTS_UFC_LEAGUE_ID=1  (optional override — default is 1 = UFC)

# Legacy RapidAPI (still works if APISPORTS_KEY is not set)
# RAPIDAPI_KEY=your-rapidapi-key-here
# RAPIDAPI_UFC_HOST=mmaapi.p.rapidapi.com

# Cron job secret — set this in Vercel env vars and pass as Authorization: Bearer <secret>
# CRON_SECRET=your-random-secret-here

# Optional features
# ANTHROPIC_API_KEY=your-anthropic-key  (AI matchup analysis on event import)
# RESEND_API_KEY=your-resend-key        (email notifications)
# ODDS_API_KEY=your-odds-api-key        (live betting odds sync)
# YOUTUBE_API_KEY=your-youtube-key      (fighter profile highlights)
